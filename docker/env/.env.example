# Required: Telegram bot + admin ACL
MASIX_TELEGRAM_BOT_TOKEN=REPLACE_WITH_BOTFATHER_TOKEN
MASIX_ADMIN_IDS=123456789

# Required: choose active provider name among configured keys below
MASIX_ACTIVE_PROVIDER=openai

# Optional bot metadata/policy
MASIX_BOT_NAME=
MASIX_AUTO_REGISTER_USERS=true
MASIX_NOTIFY_ADMIN_ON_NEW_USER=true
MASIX_NEW_USER_WELCOME_MESSAGE=Welcome! I am online and ready to help.
MASIX_GROUP_MODE=all
MASIX_USER_TOOLS_MODE=none
MASIX_REGISTER_TO_FILE=/data/register/telegram_users.json
MASIX_POLL_TIMEOUT_SECS=60

# Optional streaming (private chats use telegram_draft)
MASIX_ENABLE_STREAMING=true
MASIX_STREAMING_MODE=telegram_draft

# Provider keys (set one or more)
MASIX_PROVIDER_OPENAI_KEY=
MASIX_PROVIDER_OPENROUTER_KEY=
MASIX_PROVIDER_ZAI_KEY=
MASIX_PROVIDER_ZAI_CODING_KEY=
MASIX_PROVIDER_ANTHROPIC_KEY=
MASIX_PROVIDER_GEMINI_KEY=
MASIX_PROVIDER_XAI_KEY=
MASIX_PROVIDER_GROQ_KEY=
MASIX_PROVIDER_DEEPSEEK_KEY=
MASIX_PROVIDER_MISTRAL_KEY=
MASIX_PROVIDER_TOGETHER_KEY=
MASIX_PROVIDER_FIREWORKS_KEY=
MASIX_PROVIDER_COHERE_KEY=
MASIX_PROVIDER_ALIBABA_MODEL_STUDIO_KEY=
MASIX_PROVIDER_ALIBABA_CODING_PLAN_KEY=
MASIX_PROVIDER_ALIBABA_ANTHROPIC_KEY=

# Optional model overrides
MASIX_PROVIDER_OPENAI_MODEL=
MASIX_PROVIDER_OPENROUTER_MODEL=
MASIX_PROVIDER_ZAI_MODEL=
MASIX_PROVIDER_ZAI_CODING_MODEL=
MASIX_PROVIDER_ANTHROPIC_MODEL=
MASIX_PROVIDER_GEMINI_MODEL=
MASIX_PROVIDER_XAI_MODEL=
MASIX_PROVIDER_GROQ_MODEL=
MASIX_PROVIDER_DEEPSEEK_MODEL=
MASIX_PROVIDER_MISTRAL_MODEL=
MASIX_PROVIDER_TOGETHER_MODEL=
MASIX_PROVIDER_FIREWORKS_MODEL=
MASIX_PROVIDER_COHERE_MODEL=
MASIX_PROVIDER_ALIBABA_MODEL_STUDIO_MODEL=
MASIX_PROVIDER_ALIBABA_CODING_PLAN_MODEL=
MASIX_PROVIDER_ALIBABA_ANTHROPIC_MODEL=

# Optional custom provider
# MASIX_PROVIDER_CUSTOM_KEY=
# MASIX_PROVIDER_CUSTOM_BASE_URL=
# MASIX_PROVIDER_CUSTOM_MODEL=

